# Unified environment variables template

# Postgres connection
POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=odoo-db
POSTGRES_PORT=5432

# Odoo admin (master password)
ODOO_ADMIN_PASSWORD=changeme

# Frontend Odoo URLs
ODOO_API_BASE_URL=http://odoo:8069
ODOO_PORT=9000
NEXT_PUBLIC_ODOO_API_BASE_URL=http://localhost:9000
