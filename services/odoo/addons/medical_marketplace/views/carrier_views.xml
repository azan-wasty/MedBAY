<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Shipping Carriers: list view -->
    <record id="medical_carrier_view_tree" model="ir.ui.view">
        <field name="name">medical.carrier.tree</field>
        <field name="model">medical.carrier</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="tracking_url_template"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Shipping Carriers: form view -->
    <record id="medical_carrier_view_form" model="ir.ui.view">
        <field name="name">medical.carrier.form</field>
        <field name="model">medical.carrier</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="tracking_url_template"
                               placeholder="e.g. https://www.dhl.com/en/express/tracking.html?AWB={tracking_id}"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <p>Use <strong>{tracking_id}</strong> as the placeholder in the URL template.
                        It will be replaced automatically with the actual tracking reference when
                        generating buyer-facing tracking links.</p>
                        <p>To add a new carrier without code changes, duplicate this record and save.
                        Or add a &lt;record&gt; block in <code>data/carrier_config.xml</code>
                        and upgrade the module.</p>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Return Reasons: list view -->
    <record id="medical_return_reason_view_tree" model="ir.ui.view">
        <field name="name">medical.return.reason.tree</field>
        <field name="model">medical.return.reason</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Actions -->
    <record id="medical_carrier_action" model="ir.actions.act_window">
        <field name="name">Shipping Carriers</field>
        <field name="res_model">medical.carrier</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="medical_return_reason_action" model="ir.actions.act_window">
        <field name="name">Return Reasons</field>
        <field name="res_model">medical.return.reason</field>
        <field name="view_mode">tree</field>
    </record>

    <!-- Menu items under Medical Marketplace > Configuration -->
    <menuitem id="menu_medical_marketplace_config" name="Configuration"
              parent="menu_medical_marketplace_root"
              sequence="90"/>
    <menuitem id="menu_medical_carriers" name="Shipping Carriers"
              parent="menu_medical_marketplace_config"
              action="medical_carrier_action" sequence="10"/>
    <menuitem id="menu_medical_return_reasons" name="Return Reasons"
              parent="menu_medical_marketplace_config"
              action="medical_return_reason_action" sequence="20"/>
</odoo>
