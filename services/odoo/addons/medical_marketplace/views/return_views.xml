<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="medical_return_request_view_tree" model="ir.ui.view">
        <field name="name">medical.return.request.tree</field>
        <field name="model">medical.return.request</field>
        <field name="arch" type="xml">
            <tree decoration-danger="state == 'rejected'"
                  decoration-success="state == 'done'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="reason_category_id"/>
                <field name="return_type"/>
                <field name="request_date"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="medical_return_request_view_form" model="ir.ui.view">
        <field name="name">medical.return.request.form</field>
        <field name="model">medical.return.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve"
                            class="btn-primary" invisible="state != 'requested'"/>
                    <button name="action_reject" type="object" string="Reject"
                            invisible="state != 'requested'"/>
                    <button name="action_process_refund" type="object" string="Process Refund / Replacement"
                            class="btn-primary" invisible="state != 'approved'"/>
                    <button name="action_mark_done" type="object" string="Mark Done"
                            class="btn-primary" invisible="state not in ('refunded', 'replaced')"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('done', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,requested,approved,refunded,replaced,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="sale_order_id"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="order_line_id"/>
                            <field name="product_id"/>
                            <field name="quantity"/>
                        </group>
                        <group>
                            <field name="return_type"/>
                            <field name="request_date" readonly="1"/>
                            <field name="delivery_picking_id"/>
                            <field name="return_picking_id" readonly="1"/>
                            <field name="refund_move_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Return Details">
                        <field name="reason_category_id"/>
                        <field name="reason_detail" placeholder="Optional: provide additional context..."/>
                        <field name="admin_notes" placeholder="Internal notes (admin only, not visible to buyer)"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="medical_return_request_action" model="ir.actions.act_window">
        <field name="name">Return Requests</field>
        <field name="res_model">medical.return.request</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No return requests yet. They can be created here by staff
                or submitted by customers through the marketplace API.
            </p>
        </field>
    </record>

    <menuitem id="menu_medical_marketplace_root" name="Medical Marketplace" sequence="50"/>
    <menuitem id="menu_medical_return_requests" name="Returns"
              parent="menu_medical_marketplace_root"
              action="medical_return_request_action" sequence="10"/>
</odoo>
